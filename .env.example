# URL pública del sitio (para sitemap/metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Publicación cerrada (preview privada) ---
# Activar para proteger el sitio completo con usuario/contraseña.
CLOSED_PREVIEW_ENABLED=false
CLOSED_PREVIEW_USER=
CLOSED_PREVIEW_PASSWORD=

# --- Integraciones opcionales ---
# Calendly (por ejemplo: https://calendly.com/tuusuario/tu-evento)
NEXT_PUBLIC_CALENDLY_URL=

# Newsletter embed (Brevo/Mailchimp) - si usas un iframe o script, pega URL aquí
NEXT_PUBLIC_NEWSLETTER_EMBED_URL=

# Contacto (Formspree, etc.)
NEXT_PUBLIC_CONTACT_FORM_ACTION=
